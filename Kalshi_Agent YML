name: Kalshi Weather Agent

on:
  schedule:
    - cron: "*/20 * * * *"   # Every 20 minutes, all day, every day
  workflow_dispatch:

jobs:
  run-agent:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: pip install requests cryptography

      - name: Run Kalshi weather agent
        env:
          KALSHI_API_KEY_ID:  ${{ secrets.KALSHI_API_KEY_ID }}
          KALSHI_PRIVATE_KEY: ${{ secrets.KALSHI_PRIVATE_KEY }}
          EMAIL_FROM:         ${{ secrets.EMAIL_FROM }}
          EMAIL_PASSWORD:     ${{ secrets.EMAIL_PASSWORD }}
        run: python kalshi_agent.py

      - name: Upload log
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: kalshi-log-${{ github.run_number }}
          path: kalshi_log.txt
